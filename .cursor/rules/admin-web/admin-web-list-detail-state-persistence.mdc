### Step 3: Detail Page Hook - Return State to List

**Location**: `src/features/{domain}/{entity}/detail/model/useXxxDetail.ts`

**MUST:**

```typescript
import { useRouter } from "next/navigation";

export function useXxxDetail(id: string | null) {
  const router = useRouter();

  const handleList = () => {
    // MUST: Read query params from current URL
    if (typeof window !== "undefined") {
      const searchParams = new URLSearchParams(window.location.search);
      const searchCondition = searchParams.get("searchCondition") || "";
      const searchKeyword = searchParams.get("searchKeyword") || "";
      const joGunMberSta = searchParams.get("joGunMberSta") || "";
      const page = searchParams.get("page") || "1";

      // MUST: Build query params (only include non-empty values)
      const params = new URLSearchParams();
      if (searchCondition) params.set("searchCondition", searchCondition);
      if (searchKeyword) params.set("searchKeyword", searchKeyword);
      if (joGunMberSta) params.set("joGunMberSta", joGunMberSta);
      if (page) params.set("page", page);

      // MUST: Navigate back to list with preserved state
      const queryString = params.toString();
      router.push(
        queryString ? `/adminWeb/xxx/list?${queryString}` : "/adminWeb/xxx/list"
      );
    } else {
      // SSR fallback
      router.push("/adminWeb/xxx/list");
    }
  };

  return {
    // ... other returns
    handleList,
  };
}
```

**MUST NOT:**

```typescript
// ❌ WRONG: Don't navigate without preserving params
const handleList = () => {
  router.push("/adminWeb/xxx/list"); // Lost state!
};

// ❌ WRONG: Don't forget window check for SSR
const searchParams = new URLSearchParams(window.location.search);
// Should check typeof window !== "undefined"

// ❌ WRONG: Don't include empty values in URL
params.set("searchKeyword", searchKeyword); // Should check if not empty
```

