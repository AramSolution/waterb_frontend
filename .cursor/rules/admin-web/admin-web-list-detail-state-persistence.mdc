### Step 2: List Page Component - Pass State to Detail

**Location**: `src/app/{domain}/{entity}/list/page.tsx`

**MUST:**

```typescript
"use client";

import { Suspense } from "react";
import { useRouter } from "next/navigation";

function XxxListContent() {
  const router = useRouter();
  const {
    searchCondition,
    searchKeyword,
    joGunMberSta,
    currentPage,
    // ... other state
  } = useXxxList();

  // MUST: When navigating to detail, include current state as query params
  const handleDetailClick = (id: string) => {
    const params = new URLSearchParams({
      esntlId: id, // Detail page identifier
      searchCondition: searchCondition || "1",
      searchKeyword: searchKeyword || "",
      joGunMberSta: joGunMberSta || "",
      page: currentPage.toString(),
    });
    router.push(`/adminWeb/xxx/detail?${params.toString()}`);
  };

  return (
    <AdminLayout>
      {/* ... list UI ... */}
      <button onClick={() => handleDetailClick(item.id)}>상세</button>
    </AdminLayout>
  );
}

// MUST: Wrap with Suspense when using useSearchParams
// MUST: Use LoadingFallback component (not inline UI markup)
import { LoadingFallback } from "@/shared/ui/adminWeb";

export default function XxxListPage() {
  return (
    <Suspense fallback={<LoadingFallback />}>
      <XxxListContent />
    </Suspense>
  );
}
```

**MUST NOT:**

```typescript
// ❌ WRONG: Don't navigate without query params
router.push(`/adminWeb/xxx/detail?esntlId=${id}`);

// ❌ WRONG: Don't forget Suspense wrapper
export default function XxxListPage() {
  return <XxxListContent />; // Missing Suspense
}

// ❌ WRONG: Don't hardcode values
const params = new URLSearchParams({
  esntlId: id,
  searchCondition: "1", // Should use actual state value
});
```

