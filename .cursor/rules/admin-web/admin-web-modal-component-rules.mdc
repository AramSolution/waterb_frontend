## ✅ CORRECT: API Communication Error Handling Pattern

**MUST follow this exact pattern for all API communication errors:**

```typescript
// ✅ CORRECT: Using ConfirmDialog for API errors
const handleSubmit = async (e: React.FormEvent) => {
  e.preventDefault();

  if (!validateForm()) {
    return; // Client-side validation errors can use red text if needed
  }

  setLoading(true);
  setError(""); // ✅ Initialize, but don't use for API errors

  try {
    const response = await SomeService.create({ /* params */ });

    if (response.result === "00") {
      // Success handling
      setMessageDialogTitle("등록 완료");
      setMessageDialogMessage(
        response.message || "정상적으로 등록되었습니다."
      );
      setMessageDialogType("success");
      setShowMessageDialog(true);
    } else {
      // API response indicates failure
      setMessageDialogTitle("등록 실패");
      setMessageDialogMessage(
        response.message || "등록 중 오류가 발생했습니다."
      );
      setMessageDialogType("danger"); // ✅ REQUIRED - use "danger"
      setShowMessageDialog(true);
    }
  } catch (err) {
    console.error("등록 오류:", err); // ✅ Log error for debugging
    
    // ✅ CORRECT: Use ConfirmDialog for ALL API communication errors
    if (err instanceof ApiError) {
      setMessageDialogTitle("등록 실패");
      setMessageDialogMessage(
        err.message || "등록 중 오류가 발생했습니다."
      );
      setMessageDialogType("danger"); // ✅ REQUIRED - use "danger", NOT "error"
      setShowMessageDialog(true);
    } else {
      setMessageDialogTitle("등록 실패");
      setMessageDialogMessage(
        "등록 중 알 수 없는 오류가 발생했습니다."
      );
      setMessageDialogType("danger"); // ✅ REQUIRED - use "danger"
      setShowMessageDialog(true);
    }
  } finally {
    setLoading(false);
  }
};
```

**Component structure:**

```tsx
// ✅ CORRECT: No red text for API errors
export const RegisterForm: React.FC = () => {
  const {
    // ... other state
    showMessageDialog,
    messageDialogTitle,
    messageDialogMessage,
    messageDialogType,
    handleSubmit,
    handleMessageDialogClose,
  } = useRegister();

  return (
    <>
      <form onSubmit={handleSubmit}>
        {/* Form fields */}
        {/* ❌ NO red text display for API errors */}
      </form>

      {/* ✅ CORRECT: ConfirmDialog for all API errors */}
      <ConfirmDialog
        isOpen={showMessageDialog}
        title={messageDialogTitle}
        message={messageDialogMessage}
        type={messageDialogType} // "danger" for API errors, "success" for success
        confirmText="확인"
        cancelText="닫기"
        onConfirm={handleMessageDialogClose}
        onCancel={handleMessageDialogClose}
      />
    </>
  );
};
```

