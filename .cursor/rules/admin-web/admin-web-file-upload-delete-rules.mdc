## 📋 Complete File Delete Implementation Pattern

### Step 1: Define File Item Interface

```typescript
// ✅ CORRECT: File item interface
export interface FileItem {
  fileId?: string | number; // ✅ string | number (NOT just number)
  seq?: string | number;     // ✅ string | number (NOT just number)
  orgfNm?: string;
  saveNm?: string;
  filePath?: string;
  fileExt?: string;
  fileSize?: number;
  fileType?: string;
  sttusCode?: string;
  [key: string]: unknown;
}
```

### Step 2: Define Delete API Function

```typescript
// ✅ CORRECT: Delete API function
static async deleteFile(params: {
  proId: string;
  fileId: string | number; // ✅ string | number
  seq: string | number;     // ✅ string | number
}): Promise<DeleteResponse> {
  const { proId, fileId, seq } = params;
  const response = await apiClient.delete<DeleteResponse>(
    `${API_ENDPOINTS.BASE}/${proId}/files/${fileId}/${seq}`,
  );
  return response;
}
```

### Step 3: Implement Delete Confirmation Handler

```typescript
// ✅ CORRECT: Delete confirmation handler
const handleDeleteFileClick = (file: FileItem) => {
  setFileToDelete(file);
  setShowDeleteConfirmDialog(true);
};
```

### Step 4: Implement Actual Delete Function

```typescript
// ✅ CORRECT: Actual delete function
const deleteExistingFile = async (file: FileItem) => {
  // Convert to string for comparison (handles precision)
  const fileId = file.fileId != null ? String(file.fileId) : null;
  const seq = file.seq != null ? String(file.seq) : null;

  if (!fileId || !seq) {
    setError("삭제할 파일 정보가 올바르지 않습니다.");
    return;
  }

  try {
    setLoading(true);
    setError("");

    const response = await FileService.deleteFile({
      proId: businessId,
      fileId, // Can be string or number, API handles both
      seq,
    });

    if (response.result === "00") {
      // Update file list with String() conversion
      setExistingFiles((prev) =>
        prev.filter(
          (f) => {
            return !(
              String(f.fileId) === String(fileId) &&
              String(f.seq) === String(seq)
            );
          },
        ),
      );

      // Show success message
      setMessageDialogTitle("삭제 완료");
      setMessageDialogMessage(
        response.message || "파일이 삭제되었습니다."
      );
      setMessageDialogType("success");
      setShowMessageDialog(true);
    } else {
      // Show failure message
      setMessageDialogTitle("삭제 실패");
      setMessageDialogMessage(
        response.message || "파일 삭제에 실패했습니다."
      );
      setMessageDialogType("danger");
      setShowMessageDialog(true);
    }
  } catch (err) {
    setMessageDialogTitle("삭제 실패");
    setMessageDialogMessage(
      err instanceof Error
        ? err.message
        : "파일 삭제 중 오류가 발생했습니다."
    );
    setMessageDialogType("danger");
    setShowMessageDialog(true);
  } finally {
    setLoading(false);
  }
};
```

