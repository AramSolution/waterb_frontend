## 🔄 Migration Guide: From Custom Markup to Components

### Step 1: Identify Form Fields

```tsx
// Before: Custom markup
<div className="w-full md:w-1/2 register-form-mobile-row">
  <div className="register-form-mobile-wrapper md:flex md:items-stretch">
    <label className="w-full md:w-1/4 flex items-center m-0 register-form-label bg-gray-100">
      <span className="text-red-600 mr-1">*</span> User ID
    </label>
    <div className="register-form-mobile-field w-full md:w-3/4 flex items-center">
      <div className="w-full">
        <input
          type="text"
          name="userId"
          className={`w-full border rounded-none px-3 py-2 ${
            errors.userId ? "border-red-500" : ""
          }`}
          value={formData.userId}
          onChange={handleInputChange}
        />
        {errors.userId && (
          <div className="text-red-600 text-sm mt-1 px-2">
            {errors.userId}
          </div>
        )}
      </div>
    </div>
  </div>
</div>
```

### Step 2: Replace with Components

```tsx
// After: Using components
import { FormField, FormInput } from "@/shared/ui/adminWeb/form";

<FormField
  label="User ID"
  required
  error={errors.userId}
>
  <FormInput
    type="text"
    name="userId"
    value={formData.userId}
    onChange={handleInputChange}
    error={errors.userId}
  />
</FormField>
```

### Step 3: Convert Select Options

```tsx
// Before: Raw data
<select name="siteId" value={formData.siteId} onChange={handleInputChange}>
  {siteList.map((site) => (
    <option key={site.siteId} value={site.siteId}>
      {site.siteNm}
    </option>
  ))}
</select>

// After: Convert to SelectOption format
import { FormSelect } from "@/shared/ui/adminWeb/form";
import type { SelectOption } from "@/shared/ui/adminWeb/form";

const siteOptions: SelectOption[] = siteList.map((site) => ({
  value: site.siteId,
  label: site.siteNm,
}));

<FormSelect
  name="siteId"
  value={formData.siteId}
  onChange={handleInputChange}
  options={siteOptions}
/>
```

### Step 4: Convert Radio Buttons

```tsx
// Before: Manual radio buttons
<div className="inline-flex items-center mb-0 mr-4">
  <input
    type="radio"
    name="status"
    value="A"
