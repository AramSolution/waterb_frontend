    type="radio"
    name="status"
    value="D"
    checked={formData.status === "D"}
    onChange={handleRadioChange}
  />
  <label>Deleted</label>
</div>

// After: Using FormRadioGroup
import { FormRadioGroup } from "@/shared/ui/adminWeb/form";
import type { RadioOption } from "@/shared/ui/adminWeb/form";

const statusOptions: RadioOption[] = [
  { value: "A", label: "Active" },
  { value: "D", label: "Deleted" },
];

<FormRadioGroup
  name="status"
  value={formData.status}
  onChange={handleRadioChange}
  options={statusOptions}
