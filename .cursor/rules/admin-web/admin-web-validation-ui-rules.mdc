## 🚫 Common Mistakes to Avoid

### Mistake 1: Not Using Components

```tsx
// ❌ WRONG: Creating custom markup instead of using components
<div className="register-form-mobile-field w-full md:w-3/4">
  <input type="text" name="userId" />
</div>
```

**Fix:**

```tsx
// ✅ CORRECT: Use FormField and FormInput
<FormField label="User ID">
  <FormInput
    type="text"
    name="userId"
    value={formData.userId}
    onChange={handleInputChange}
  />
</FormField>
```

### Mistake 2: Wrong Data Format for Select

```tsx
// ❌ WRONG: Passing raw array instead of SelectOption[]
<FormSelect
  name="siteId"
  options={siteList} // ❌ Wrong format
/>
```

**Fix:**

```tsx
// ✅ CORRECT: Convert to SelectOption format
const siteOptions: SelectOption[] = siteList.map((site) => ({
  value: site.siteId,
  label: site.siteNm,
}));

<FormSelect name="siteId" options={siteOptions} />
```

### Mistake 3: Missing Error Prop

```tsx
// ❌ WRONG: Error not passed to component
<FormField label="User ID" required>
  <FormInput
    name="userId"
    value={formData.userId}
    onChange={handleInputChange}
    // ❌ Missing error prop
  />
</FormField>
```

**Fix:**

```tsx
// ✅ CORRECT: Pass error to both FormField and FormInput
<FormField label="User ID" required error={errors.userId}>
  <FormInput
    name="userId"
    value={formData.userId}
    onChange={handleInputChange}
    error={errors.userId} // ✅ Error passed
  />
</FormField>
```

### Mistake 4: Incorrect Border Props

```tsx
// ❌ WRONG: All fields have isFirstRow=true
<FormField label="Field 1" isFirstRow> {/* ❌ Only first field should have this */}
<FormField label="Field 2" isFirstRow> {/* ❌ Wrong */}
<FormField label="Field 3" isFirstRow> {/* ❌ Wrong */}
```

**Fix:**

```tsx
// ✅ CORRECT: Only first field in first row has isFirstRow and isFirstInRow
<div className="flex flex-wrap">
  <FormField label="Field 1" isFirstRow isFirstInRow>
    <FormInput ... />
  </FormField>
  <FormField label="Field 2" isFirstInRow>
    <FormInput ... />
  </FormField>
</div>
<div className="flex flex-wrap">
  <FormField label="Field 3">
    <FormInput ... />
  </FormField>
  <FormField label="Field 4" isFirstInRow>
    <FormInput ... />
  </FormField>
</div>
```

### Mistake 5: Mixing Components with Custom Markup

```tsx
// ❌ WRONG: Using FormField but custom input
<FormField label="User ID">
  <input
    type="text"
    name="userId"
    className="custom-class"
    // ❌ Should use FormInput
  />
</FormField>
```

**Fix:**

```tsx
// ✅ CORRECT: Use FormInput component
<FormField label="User ID">
  <FormInput
    type="text"
    name="userId"
    value={formData.userId}
    onChange={handleInputChange}
    className="custom-class" // ✅ Can still add custom classes
  />
</FormField>
```

