### Step 3: API Call Strategy

**For Server-Side Pagination + Server-Side Filtering:**

```typescript
// ✅ CORRECT: Fetch function with minimal dependencies
const fetchMembers = useCallback(async () => {
  const startIndex = (currentPage - 1) * pageSize;
  const params = {
    // Use refs, not state directly
    searchCondition: searchConditionRef.current,
    searchKeyword: searchKeywordRef.current,
    length: pageSize.toString(),
    start: startIndex.toString(),
    // Note: Additional server-side filter parameters can be added here if needed
    // All filtering is done server-side, not client-side
  };

  const response = await Service.getList(params);
  setMembers(response.data || []);
  setTotalElements(response.recordsTotal || 0);
}, [currentPage, pageSize]); // ⚠️ Only page-related dependencies

// ✅ CORRECT: Page change triggers API
useEffect(() => {
  if (!isInitialLoad) {
    fetchMembers();
  }
}, [currentPage, fetchMembers, isInitialLoad]);

// ✅ CORRECT: Filters with Debounce (use ref to avoid dependency issues)
useEffect(() => {
  if (isInitialLoad) return;

  const timer = setTimeout(() => {
    setCurrentPage(1);
    fetchMembersRef.current(); // Use ref, not fetchMembers directly
  }, 800);

  return () => clearTimeout(timer);
}, [
  filters.userId,
  filters.userNm /* ... other filter fields */,
  ,
  isInitialLoad,
]);

// ✅ CORRECT: Explicit search (NO automatic search)
const handleSearch = () => {
  setCurrentPage(1);
  fetchMembers();
};
```

