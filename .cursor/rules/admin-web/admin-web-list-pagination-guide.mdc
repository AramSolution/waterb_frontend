## 📝 Code Template

### Server-Side Pagination + Server-Side Filtering Pattern (STANDARD):

```typescript
import { useState, useEffect, useRef, useCallback } from "react";

export function useListPage() {
  // State
  const [members, setMembers] = useState<Item[]>([]);
  const [totalElements, setTotalElements] = useState(0);
  const [totalPages, setTotalPages] = useState(0);
  const [currentPage, setCurrentPage] = useState(1);
  const [isInitialLoad, setIsInitialLoad] = useState(true);
  const [loading, setLoading] = useState(true);

  // Search conditions (server-side filtering via API)
  const [searchCondition, setSearchCondition] = useState("1");
  const [searchKeyword, setSearchKeyword] = useState("");

  const pageSize = 15;

  // Refs for stable references
  const searchConditionRef = useRef(searchCondition);
  const searchKeywordRef = useRef(searchKeyword);

  // Update refs when state changes
  useEffect(() => {
    searchConditionRef.current = searchCondition;
  }, [searchCondition]);

  useEffect(() => {
    searchKeywordRef.current = searchKeyword;
  }, [searchKeyword]);

  // Fetch function (minimal dependencies)
  const fetchMembers = useCallback(async () => {
    try {
      setLoading(true);
      const startIndex = (currentPage - 1) * pageSize;
      const params = {
        searchCondition: searchConditionRef.current,
        searchKeyword: searchKeywordRef.current,
        length: pageSize.toString(),
        start: startIndex.toString(),
        // Note: Additional server-side filter parameters can be added here if needed
        // All filtering is done server-side, not client-side
      };

      const response = await Service.getList(params);
      setMembers(response.data || []);
      setTotalElements(response.recordsTotal || 0);
      setTotalPages(Math.ceil((response.recordsTotal || 0) / pageSize));
    } catch (err) {
      console.error("Data fetch failed:", err);
    } finally {
      setLoading(false);
      setIsInitialLoad(false);
    }
  }, [currentPage, pageSize]);

  // Ref for fetchMembers
  const fetchMembersRef = useRef(fetchMembers);
  useEffect(() => {
    fetchMembersRef.current = fetchMembers;
  }, [fetchMembers]);

  // Initial load
  useEffect(() => {
    fetchMembers();
  }, []);

  // Page change
  useEffect(() => {
    if (!isInitialLoad) {
      fetchMembers();
    }
  }, [currentPage, fetchMembers, isInitialLoad]);

  // Explicit search handler (server-side filtering)
  const handleSearch = () => {
    setCurrentPage(1);
    fetchMembers();
  };

  return {
    members,
    totalElements,
    totalPages,
    currentPage,
    setCurrentPage,
    loading,
    filters,
    setFilters,
    showFilters,
    setShowFilters,
    handleSearch,
    handleClearFilters,
    searchCondition,
    setSearchCondition,
    searchKeyword,
    setSearchKeyword,
  };
}
```

