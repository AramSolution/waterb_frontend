### Step 2: State Structure

**MUST create separate states for server-side pattern:**

```typescript
// ✅ CORRECT: Server-side pattern states
const [members, setMembers] = useState<Item[]>([]); // Current page data
const [totalElements, setTotalElements] = useState(0); // Total count from server
const [totalPages, setTotalPages] = useState(0); // Calculated from totalElements
const [currentPage, setCurrentPage] = useState(1);
const [isInitialLoad, setIsInitialLoad] = useState(true);

// Search conditions (server-side filtering via API)
const [searchCondition, setSearchCondition] = useState("1");
const [searchKeyword, setSearchKeyword] = useState("");

// ✅ CORRECT: useRef for stable references
// Note: NO filters state - all filtering is done server-side via API parameters
const searchConditionRef = useRef(searchCondition);
const searchKeywordRef = useRef(searchKeyword);
const fetchMembersRef = useRef(fetchMembers);

// ❌ WRONG: Single state for everything
const [data, setData] = useState<Item[]>([]); // Don't do this!
```

